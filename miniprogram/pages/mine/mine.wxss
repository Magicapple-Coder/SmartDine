.bind-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 48rpx 32rpx;
}

.avatar-picker {
  width: 112rpx;
  height: 112rpx;
  min-width: 0;
  padding: 0;
  border-radius: 50%;
  background: var(--brand-soft);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 52rpx;
  margin-bottom: 20rpx;
  overflow: hidden;
}

.avatar-picker::after {
  border: none;
}

.avatar-picker .avatar-img {
  width: 100%;
  height: 100%;
  border-radius: 50%;
}

.bind-card .title {
  font-weight: 700;
  font-size: 30rpx;
  text-align: center;
}

.bind-card .sub {
  color: var(--ink-3);
  font-size: 23rpx;
  margin-top: 8rpx;
  margin-bottom: 28rpx;
  text-align: center;
}

.field-input {
  width: 100%;
  background: var(--surface-2);
  border: 1rpx solid var(--line);
  border-radius: 12rpx;
  padding: 20rpx;
  margin-bottom: 18rpx;
  font-size: 27rpx;
  line-height: 1.4;
  box-sizing: border-box;
}

/* ---------- 会员卡头部头像 ---------- */
.member-head {
  display: flex;
  align-items: center;
}

.member-avatar-img {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.member-avatar-fallback {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.12);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.bind-btn {
  width: 100%;
  margin-top: 6rpx;
}

/* ---------- 会员卡 ---------- */
.member-card {
  background: linear-gradient(135deg, #2b2622, #211e1b);
  border-radius: 24rpx;
  padding: 32rpx 28rpx;
  color: #fff;
  margin-bottom: 20rpx;
  box-shadow: 0 12rpx 28rpx rgba(33, 30, 27, 0.25);
}

.member-name {
  font-size: 32rpx;
  font-weight: 700;
}

.member-phone {
  font-size: 23rpx;
  color: rgba(255, 255, 255, 0.5);
  margin-top: 6rpx;
}

.level-tag {
  background: var(--brand);
  color: #fff;
  padding: 4rpx 20rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 600;
}

.stat-row {
  display: flex;
  align-items: center;
  margin-top: 28rpx;
  padding-top: 24rpx;
  border-top: 1rpx solid rgba(255, 255, 255, 0.12);
}

.stat {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-sep {
  width: 1rpx;
  height: 48rpx;
  background: rgba(255, 255, 255, 0.12);
}

.stat-value {
  font-size: 30rpx;
  font-weight: 700;
}

.stat-label {
  font-size: 21rpx;
  color: rgba(255, 255, 255, 0.5);
  margin-top: 4rpx;
}

/* ---------- 偏好卡 ---------- */
.edit-link {
  color: var(--brand);
  font-size: 24rpx;
  font-weight: 600;
}

.pref-text {
  margin-top: 10rpx;
}

.note-input {
  width: 100%;
  height: 120rpx;
  margin: 16rpx 0;
  background: var(--surface-2);
  border: 1rpx solid var(--line);
  border-radius: 12rpx;
  padding: 16rpx;
  font-size: 26rpx;
  box-sizing: border-box;
}

.logout-btn {
  text-align: center;
  margin-top: 36rpx;
  color: var(--ink-3);
  font-size: 25rpx;
  padding: 16rpx 0;
}
