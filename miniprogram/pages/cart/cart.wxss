.cart-item {
  display: flex;
  align-items: center;
}

.item-thumb {
  width: 80rpx;
  height: 80rpx;
  border-radius: 14rpx;
  background: var(--surface-2);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  flex-shrink: 0;
}

.item-info {
  flex: 1;
  margin: 0 16rpx;
  min-width: 0;
}

.item-name {
  font-size: 27rpx;
  font-weight: 600;
}

.item-price {
  color: var(--brand);
  font-weight: 600;
  margin-top: 6rpx;
}

.remove {
  color: var(--ink-3);
  font-size: 23rpx;
  margin-left: 20rpx;
  flex-shrink: 0;
}

.bar-total {
  font-size: 26rpx;
  color: var(--ink-2);
}

.bar-amount {
  color: var(--brand);
  font-size: 32rpx;
  font-weight: 700;
  margin-left: 6rpx;
}

.submit-btn {
  margin: 0;
  padding: 0 40rpx;
}
