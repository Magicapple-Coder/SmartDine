<view class="chat-page">
  <scroll-view class="msg-list" scroll-y scroll-into-view="bottom">
    <view wx:for="{{messages}}" wx:key="index" class="msg-row {{item.role}}">
      <view class="agent-avatar" style="background: var(--c-order-soft); color: var(--c-order)" wx:if="{{item.role === 'agent'}}">🤖</view>
      <view class="bubble">{{item.text}}</view>
    </view>
    <view id="bottom"></view>
  </scroll-view>

  <view class="input-bar">
    <input class="input" value="{{input}}" placeholder="说说您想吃什么口味..." bindinput="onInput" confirm-type="send" bindconfirm="send" />
    <button class="send-btn" size="mini" loading="{{loading}}" bindtap="send">➤</button>
  </view>
  <view class="goto-menu" bindtap="goMenu">直接看菜单 ›</view>
</view>
